<Project>
  <PropertyGroup>
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);AddRuntimeFilesToPack</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <!-- Copies deno into bin/.../runtimes/<rid>/native and packs it into NuGet the same way -->
  <Target Name="CopyDenoToRuntimeFolder" AfterTargets="Build">
    <PropertyGroup>
      <RidOutputDir>$(TargetDir)runtimes/$(RuntimeRid)/native</RidOutputDir>
      <DenoSrc>$(MSBuildProjectDirectory)/$(DenoFileName)</DenoSrc>
      <DenoDst>$(RidOutputDir)/$(DenoFileName)</DenoDst>
      <DenoChecksumFileName>$(DenoFileName).sha256sum</DenoChecksumFileName>
      <DenoChecksumSrc>$(MSBuildProjectDirectory)/$(DenoChecksumFileName)</DenoChecksumSrc>
      <DenoChecksumDst>$(RidOutputDir)/$(DenoChecksumFileName)</DenoChecksumDst>
      <DenoMetadataFileName>deno.metadata.json</DenoMetadataFileName>
      <DenoMetadataSrc>$(MSBuildProjectDirectory)/$(DenoMetadataFileName)</DenoMetadataSrc>
      <DenoMetadataDst>$(RidOutputDir)/$(DenoMetadataFileName)</DenoMetadataDst>
      <DenoMetadataSigFileName>deno.metadata.sig</DenoMetadataSigFileName>
      <DenoMetadataSigSrc>$(MSBuildProjectDirectory)/$(DenoMetadataSigFileName)</DenoMetadataSigSrc>
      <DenoMetadataSigDst>$(RidOutputDir)/$(DenoMetadataSigFileName)</DenoMetadataSigDst>
    </PropertyGroup>

    <Message Importance="high" Text="Copying $(DenoFileName) from: $(DenoSrc) to: $(DenoDst)" />
    <MakeDir Directories="$(RidOutputDir)" />

    <Copy Condition="Exists('$(DenoSrc)')" SourceFiles="$(DenoSrc)"
          DestinationFiles="$(DenoDst)" SkipUnchangedFiles="true" />

        <Copy Condition="Exists('$(DenoChecksumSrc)')" SourceFiles="$(DenoChecksumSrc)"
          DestinationFiles="$(DenoChecksumDst)" SkipUnchangedFiles="true" />

        <Copy Condition="Exists('$(DenoMetadataSrc)')" SourceFiles="$(DenoMetadataSrc)"
          DestinationFiles="$(DenoMetadataDst)" SkipUnchangedFiles="true" />

        <Copy Condition="Exists('$(DenoMetadataSigSrc)')" SourceFiles="$(DenoMetadataSigSrc)"
          DestinationFiles="$(DenoMetadataSigDst)" SkipUnchangedFiles="true" />

    <!-- Ensure executable bit on Unix -->
    <Exec Condition="$([MSBuild]::IsOsUnixLike()) and Exists('$(DenoDst)')" Command="chmod +x '$(DenoDst)'" />
  </Target>

  <!-- Add files to package via SDK-specific content pipeline. -->
  <Target Name="AddRuntimeFilesToPack">
    <ItemGroup>
      <TfmSpecificPackageFile Include="$(MSBuildProjectDirectory)/$(DenoFileName)"
                              Condition="Exists('$(MSBuildProjectDirectory)/$(DenoFileName)')">
        <PackagePath>runtimes/$(RuntimeRid)/native/</PackagePath>
      </TfmSpecificPackageFile>

      <TfmSpecificPackageFile Include="$(MSBuildProjectDirectory)/$(DenoFileName).sha256sum"
                              Condition="Exists('$(MSBuildProjectDirectory)/$(DenoFileName).sha256sum')">
        <PackagePath>runtimes/$(RuntimeRid)/native/</PackagePath>
      </TfmSpecificPackageFile>

      <TfmSpecificPackageFile Include="$(MSBuildProjectDirectory)/deno.metadata.json"
                              Condition="Exists('$(MSBuildProjectDirectory)/deno.metadata.json')">
        <PackagePath>runtimes/$(RuntimeRid)/native/</PackagePath>
      </TfmSpecificPackageFile>

      <TfmSpecificPackageFile Include="$(MSBuildProjectDirectory)/deno.metadata.sig"
                              Condition="Exists('$(MSBuildProjectDirectory)/deno.metadata.sig')">
        <PackagePath>runtimes/$(RuntimeRid)/native/</PackagePath>
      </TfmSpecificPackageFile>
    </ItemGroup>
  </Target>
</Project>
